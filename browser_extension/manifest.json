{
  "manifest_version": 3,
  "name": "Semantic Firewall Guard",
  "description": "Scan prompt text with Semantic Firewall before sending it.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Semantic Firewall Guard"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://localhost:8000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
